docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#avoid","content":"Do not use batching to hide write side effects."},"423":{"id":"/docs/reference/batcher-22","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#avoid","content":"Prefer explicit write orchestration for mutations, and use `yieldless/batcher` for read-like keyed loading."},"424":{"id":"/docs/reference/breaker","page_id":"/docs/reference/breaker","type":"page","content":"yieldless/breaker","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/breaker"},"425":{"id":"/docs/reference/breaker-0","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"Circuit breakers for flaky tuple-returning dependencies."},"426":{"id":"/docs/reference/breaker-1","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#exports","content":"Exports"},"427":{"id":"/docs/reference/breaker-2","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#example","content":"Example"},"428":{"id":"/docs/reference/breaker-3","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#behavior-notes","content":"Behavior notes"},"429":{"id":"/docs/reference/breaker-4","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#good","content":"Good"},"430":{"id":"/docs/reference/breaker-5","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#avoid","content":"Avoid"},"431":{"id":"/docs/reference/breaker-6","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"`yieldless/breaker` protects a dependency after repeated failures. It tracks a small state machine: `closed`, `open`, and `half-open`. When enough failures trip the breaker, new calls fail fast with `CircuitOpenError` until the cooldown passes."},"432":{"id":"/docs/reference/breaker-7","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"Use it around external services, subprocess-heavy integrations, or any expensive boundary where repeated failures should stop causing more pressure."},"433":{"id":"/docs/reference/breaker-8","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`createCircuitBreaker(operation, options): CircuitBreaker`"},"434":{"id":"/docs/reference/breaker-9","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`class CircuitOpenError extends Error`"},"435":{"id":"/docs/reference/breaker-10","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreakerState = \"closed\" | \"half-open\" | \"open\"`"},"436":{"id":"/docs/reference/breaker-11","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreakerOptions = { failureThreshold, cooldownMs, successThreshold, shouldTrip, onStateChange }`"},"437":{"id":"/docs/reference/breaker-12","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreaker = callable & { state, failureCount, reset }`"},"438":{"id":"/docs/reference/breaker-13","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"The breaker opens after `failureThreshold` tripping failures."},"439":{"id":"/docs/reference/breaker-14","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"While open, calls return `[new CircuitOpenError(), null]`."},"440":{"id":"/docs/reference/breaker-15","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"After `cooldownMs`, the next call moves the breaker to `half-open`."},"441":{"id":"/docs/reference/breaker-16","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"A half-open success closes the breaker once `successThreshold` is reached."},"442":{"id":"/docs/reference/breaker-17","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"A half-open failure opens it again."},"443":{"id":"/docs/reference/breaker-18","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"`shouldTrip(error)` lets you ignore expected failures such as validation errors."},"444":{"id":"/docs/reference/breaker-19","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"`reset()` closes the breaker and clears counts."},"445":{"id":"/docs/reference/breaker-20","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#good","content":"Trip only on dependency failures, not user input."},"446":{"id":"/docs/reference/breaker-21","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#good","content":"Expose breaker state for diagnostics."},"447":{"id":"/docs/reference/breaker-22","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#avoid","content":"Do not use a circuit breaker for ordinary validation or authorization branches."},"448":{"id":"/docs/reference/breaker-23","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#avoid","content":"Use it for unstable boundaries where failing fast reduces damage."},"449":{"id":"/docs/reference/cache","page_id":"/docs/reference/cache","type":"page","content":"yieldless/cache","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"u
id","content":"Avoid"},"446":{"id":"/docs/reference/cache-6","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache","content":"`yieldless/cache` stores successful tuple load results and shares in-flight loads for the same key. It is useful for API clients, metadata readers, schema discovery, docs search, and any expensive async read where several callers can ask for the same thing."},"447":{"id":"/docs/reference/cache-7","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache","content":"It is intentionally small: no background worker, no global store, no runtime. The cache loads on demand, expires entries by TTL, evicts least-recently-used entries by size, and keeps errors out of the cache."},"448":{"id":"/docs/reference/cache-8","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`createCache({ load, getKey, maxSize, ttlMs }): Cache`"},"449":{"id":"/docs/reference/cache-9","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`type Cache<Key, Value, E> = { get, refresh, delete, clear, has, stats, size }`"},"450":{"id":"/docs/reference/cache-10","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`type CacheStats = { hits, misses, inFlight, size }`"},"451":{"id":"/docs/reference/cache-11","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`type CacheGetOptions = { signal?: AbortSignal }`"},"452":{"id":"/docs/reference/cache-12","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#behavior-notes","content":"Only successful `[null, value]` results are cached."},"453":{"id":"/docs/reference/cache-13","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#behavior-notes","content":"Concurrent `get()` calls for the same key sha
17","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#good-variation-add-a-remote-dependency","content":"The retry policy is attached to the flaky network call, not to the whole request."},"447":{"id":"/docs/recipes/resilient-service-flow-18","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#avoid-retrying-the-whole-handler","content":"That repeats validation, routing decisions, and any side effects. Retry the noisy boundary instead."},"448":{"id":"/docs/recipes/resilient-service-flow-19","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Validate early and return early."},"449":{"id":"/docs/recipes/resilient-service-flow-20","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Retry only the noisy boundary, not the entire request."},"450":{"id":"/docs/recipes/resilient-service-flow-21","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Spawn sibling work only when both tasks should die together."},"451":{"id":"/docs/recipes/resilient-service-flow-22","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Map domain misses to explicit HTTP errors like `NotFoundError`."},"452":{"id":"/docs/reference/all","page_id":"/docs/reference/all","type":"page","content":"yieldless/all","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/all"},"453":{"id":"/docs/reference/all-0","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all","content":"Tuple-aware parallel combinators that share cancellation."},"454":{"id":"/docs/reference/all-1","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#exports","content":"Exports"},"455":{"id":"/docs/reference/all-2","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#example","content":"Example"},"456":{"id":"/docs/reference/all-3","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#behavior-notes","content":"Behavior notes"},"457":{"id":"/docs/reference/all-4","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#when-to-prefer-runtaskgroup-instead","content":"When to prefer runTaskGroup() instead"},"458":{"id":"/docs/reference/all-5","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#good","content":"Good"},"459":{"id":"/docs/reference/all-6","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#avoid","content":"Avoid"},"460":{"id":"/docs/reference/all-7","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all","content":"`yieldless/all` gives you helpers for tuple-returning parallel work: `all(tasks)` waits for every task or aborts siblings on the first error, `race(tasks)` resolves with the first settled result and aborts the rest, and `mapLimit(items, mapper, options)` processes a collection with bounded concurrency."},"461":{"id":"/docs/reference/all-8","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`type SafeTask<T, E = Error> = (signal: AbortSignal) => PromiseLike<SafeResult<T, E>> | SafeResult<T, E>`"},"462":{"id":"/docs/reference/all-9","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`type MapLimitMapper<Item, Value, E = Error> = (item: Item, index: number, signal: AbortSignal) => PromiseLike<SafeResult<Value, E>> | SafeResult<Value, E>`"},"463":{"id":"/docs/reference/all-10","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`all(tasks, options): Promise<SafeResult<AllValues<Tasks>, ParallelError<Tasks>>>`"},"464":{"id":"/docs/reference/all-11","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`mapLimit(items, mapper, { concurrency, signal }): Promise<SafeResult<Value[], E>>`"},"465":{"id":"/docs/reference/all-12","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`race(tasks, options): Promise<SafeResult<Value, Error>>`"},"466":{"id":"/docs/reference/all-13","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#example","content":"For large batches, use `mapLimit()` to avoid starting every item at once:"},"467":{"id":"/docs/reference/all-14","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`all([])` succeeds with an empty array."},"468":{"id":"/docs/reference/all-15","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit([], mapper, options)` succeeds with an empty array."},"469":{"id":"/docs/reference/all-16","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit()` preserves input order and throws a `RangeError` when `concurrency` is less than `1` or not an integer."},"470":{"id":"/docs/reference/all-17","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race([])` throws a `RangeError`."},"471":{"id":"/docs/reference/all-18","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"If any task or mapped item returns `[error, null]`, siblings are aborted before the final tuple is returned."},"472":{"id":"/docs/reference/all-19","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race()` aborts losing tasks immediately, then waits for them to settle before it returns."},"473":{"id":"/docs/reference/all-20","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"Thrown task and mapper failures are normalized into tuple failures internally."},"474":{"id":"/docs/reference/all-21","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#when-to-prefer-runtaskgroup-instead","content":"Use `all()`, `race()`, and `mapLimit()` when the work is already tuple-native. Use `runTaskGroup()` when you want imperative fan-out and regular promise values."},"475":{"id":"/docs/reference/all-22","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `all()` for a small, fixed set of independent tuple tasks."},"476":{"id":"/docs/reference/all-23","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `mapLimit()` when a list could be large or expensive."},"477":{"id":"/docs/reference/all-24","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `race()` when the first success or first failure should settle the operation."},"478":{"id":"/docs/reference/all-25","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#avoid","content":"Do not pass work that ignores the signal and expect cancellation to be immediate."},"479":{"id":"/docs/reference/all-26","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#avoid","content":"Do not use `all()` for thousands of items. Use `mapLimit()` or `yieldless/iterable` so you can control pressure."},"480":{"id":"/docs/reference/batcher","page_id":"/docs/reference/batcher","type":"page","content":"yieldless/batcher","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/batcher"},"481":{"id":"/docs/reference/batcher-0","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"DataLoader-style keyed batching for tuple-returning async reads."},"482":{"id":"/docs/reference/batcher-1","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#exports","content":"Exports"},"483":{"id":"/docs/reference/batcher-2","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#example","content":"Example"},"484":{"id":"/docs/reference/batcher-3","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#behavior-notes","content":"Behavior notes"},"485":{"id":"/docs/reference/batcher-4","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#good","content":"Good"},"486":{"id":"/docs/reference/batcher-5","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#avoid","content":"Avoid"},"487":{"id":"/docs/reference/batcher-6","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"`yieldless/batcher` coalesces nearby `load(key)` calls into one `loadMany(keys, signal)` call. It is useful when many screens, resolvers, or workflow steps can ask for related data in the same tick."},"488":{"id":"/docs/reference/batcher-7","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"The module stays intentionally boring: it does not cache, it does not add a scheduler, and it does not require a runtime. It batches pending keys, maps results back by index, and returns tuple results to each caller."},"489":{"id":"/docs/reference/batcher-8","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`createBatcher({ loadMany, waitMs, maxBatchSize }): Batcher`"},"490":{"id":"/docs/reference/batcher-9","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`class MissingBatchResultError extends Error`"},"491":{"id":"/docs/reference/batcher-10","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`type Batcher<Key, Value, E> = { load, clear, pending }`"},"492":{"id":"/docs/reference/batcher-11","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`type BatcherLoadOptions = { signal?: AbortSignal }`"},"493":{"id":"/docs/reference/batcher-12","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`waitMs` defaults to `0`, which batches calls queued in the same turn."},"494":{"id":"/docs/reference/batcher-13","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`maxBatchSize` flushes a batch early when enough keys are waiting."},"495":{"id":"/docs/reference/batcher-14","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`loadMany()` must return values in the same order as the input keys."},"496":{"id":"/docs/reference/batcher-15","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"If `loadMany()` returns `[error, null]`, every waiting caller receives that error."},"497":{"id":"/docs/reference/batcher-16","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"If a result is missing for an index, that caller receives `MissingBatchResultError`."},"498":{"id":"/docs/reference/batcher-17","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"A pending `load()` can be aborted before the batch flushes."},"499":{"id":"/docs/reference/batcher-18","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`clear(reason)` resolves all pending loads with the reason."},"500":{"id":"/docs/reference/batcher-19","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#good","content":"Use a batcher where the backend already supports bulk reads."},"501":{"id":"/docs/reference/batcher-20","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#good","content":"Keep caching separate when you need both."},"502":{"id":"/docs/reference/batcher-21","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#avoid","content":"Do not use batching to hide write side effects."},"503":{"id":"/docs/reference/batcher-22","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#avoid","content":"Prefer explicit write orchestration for mutations, and use `yieldless/batcher` for read-like keyed loading."},"504":{"id":"/docs/reference/breaker","page_id":"/docs/reference/breaker","type":"page","content":"yieldless/breaker","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/breaker"},"505":{"id":"/docs/reference/breaker-0","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"Circuit breakers for flaky tuple-returning dependencies."},"506":{"id":"/docs/reference/breaker-1","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#exports","content":"Exports"},"507":{"id":"/docs/reference/breaker-2","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#example","content":"Example"},"508":{"id":"/docs/reference/breaker-3","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#behavior-notes","content":"Behavior notes"},"509":{"id":"/docs/reference/breaker-4","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#good","content":"Good"},"510":{"id":"/docs/reference/breaker-5","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#avoid","content":"Avoid"},"511":{"id":"/docs/reference/breaker-6","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"`yieldless/breaker` protects a dependency after repeated failures. It tracks a small state machine: `closed`, `open`, and `half-open`. When enough failures trip the breaker, new calls fail fast with `CircuitOpenError` until the cooldown passes."},"512":{"id":"/docs/reference/breaker-7","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"Use it around external services, subprocess-heavy integrations, or any expensive boundary where repeated failures should stop causing more pressure."},"513":{"id":"/docs/reference/breaker-8","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`createCircuitBreaker(operation, options): CircuitBreaker`"},"514":{"id":"/docs/reference/breaker-9","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`class CircuitOpenError extends Error`"},"515":{"id":"/docs/reference/breaker-10","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreakerState = \"closed\" | \"half-open\" | \"open\"`"},"516":{"id":"/docs/reference/breaker-11","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreakerOptions = { failureThreshold, cooldownMs, successThreshold, shouldTrip, onStateChange }`"},"517":{"id":"/docs/reference/breaker-12","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/r
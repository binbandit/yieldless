imer#sleep","content":"Sleep"},"1231":{"id":"/docs/reference/timer-3","page_id":"/docs/reference/timer","type":"heading","tags":[],"url":"/docs/reference/timer#poll","content":"Poll"},"1232":{"id":"/docs/reference/timer-4","page_id":"/docs/reference/timer","type":"heading","tags":[],"url":"/docs/reference/timer#behavior-notes","content":"Behavior notes"},"1233":{"id":"/docs/reference/timer-5","page_id":"/docs/reference/timer","type":"heading","tags":[],"url":"/docs/reference/timer#good","content":"Good"},"1234":{"id":"/docs/reference/timer-6","page_id":"/docs/reference/timer","type":"heading","tags":[],"url":"/docs/reference/timer#avoid","content":"Avoid"},"1235":{"id":"/docs/reference/timer-7","page_id":"/docs/reference/timer","tags":[],"type":"text","url":"/docs/reference/timer","content":"`yieldless/timer` covers the small timing jobs that show up around network and UI work: wait for a little while, make that wait cancelable, or poll a tuple-returning operation until it is ready."},"1236":{"id":"/docs/reference/timer-8","page_id":"/docs/reference/timer","tags":[],"type":"text","url":"/docs/reference/timer","content":"It is deliberately not a scheduler. Timers stay native, cancellation stays on `AbortSignal`, and polling returns the same tuple shape as the rest of Yieldless."},"1237":{"id":"/docs/reference/timer-9","page_id":"/docs/reference/timer","tags":[],"type":"text","url":"/docs/reference/timer#exports","content":"`sleep(delayMs, options): Promise<void>`"},"1238":{"id":"/docs/reference/timer-10","page_id":"/docs/reference/timer","tags":[],"type":"text","url":"/docs/reference/timer#exports","content":"`sleepSafe(delayMs, options): Promise<SafeResult<void, E>>`"},"1239":{"id":"/docs/reference/timer-11","page_id":"/docs/reference/timer","tags":[],"type":"text","url":"/docs/reference/timer#exports","content":"`poll(operation, options): Promise<SafeResult<T, E>>`"},"1240":{"id":"/docs/reference/timer-12","page_id":"/docs/reference/timer","tags":[],"type":"text","
ontract"},"393":{"id":"/docs/recipes/electron-git-client-2","page_id":"/docs/recipes/electron-git-client","type":"heading","tags":[],"url":"/docs/recipes/electron-git-client#main-process-implementation","content":"Main-process implementation"},"394":{"id":"/docs/recipes/electron-git-client-3","page_id":"/docs/recipes/electron-git-client","type":"heading","tags":[],"url":"/docs/recipes/electron-git-client#preload-bridge","content":"Preload bridge"},"395":{"id":"/docs/recipes/electron-git-client-4","page_id":"/docs/recipes/electron-git-client","type":"heading","tags":[],"url":"/docs/recipes/electron-git-client#renderer-usage","content":"Renderer usage"},"396":{"id":"/docs/recipes/electron-git-client-5","page_id":"/docs/recipes/electron-git-client","type":"heading","tags":[],"url":"/docs/recipes/electron-git-client#why-this-boundary-feels-cleaner","content":"Why this boundary feels cleaner"},"397":{"id":"/docs/recipes/electron-git-client-6","page_id":"/docs/recipes/electron-git-client","type":"heading","tags":[],"url":"/docs/recipes/electron-git-client#good-additions","content":"Good additions"},"398":{"id":"/docs/recipes/electron-git-client-7","page_id":"/docs/recipes/electron-git-client","type":"heading","tags":[],"url":"/docs/recipes/electron-git-client#avoid","content":"Avoid"},"399":{"id":"/docs/recipes/electron-git-client-8","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client","content":"Yieldless fits Electron well because the important boundaries in an Electron app are all failure-heavy: the renderer asks for work through IPC, the main process touches the filesystem, the main process launches long-running child processes like `git clone`."},"400":{"id":"/docs/recipes/electron-git-client-9","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#main-process-implementation","content":"If the window is torn down or a parent task group is canceled, the subprocess is aborted through Node's native child-process signal handling."},"401":{"id":"/docs/recipes/electron-git-client-10","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#why-this-boundary-feels-cleaner","content":"The renderer never depends on Electron's lossy thrown-error conversion."},"402":{"id":"/docs/recipes/electron-git-client-11","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#why-this-boundary-feels-cleaner","content":"The main process can use the same tuple style it uses everywhere else."},"403":{"id":"/docs/recipes/electron-git-client-12","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#why-this-boundary-feels-cleaner","content":"Long-running Git subprocesses can be canceled as soon as the UI no longer cares about them."},"404":{"id":"/docs/recipes/electron-git-client-13","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#good-additions","content":"Deduplicate status reads if several panels can request the same repository at once."},"405":{"id":"/docs/recipes/electron-git-client-14","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#good-additions","content":"Wait for one app or window event with cleanup."},"406":{"id":"/docs/recipes/electron-git-client-15","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#avoid","content":"Do not expose arbitrary IPC channels to the renderer."},"407":{"id":"/docs/recipes/electron-git-client-16","page_id":"/docs/recipes/electron-git-client","tags":[],"type":"text","url":"/docs/recipes/electron-git-client#avoid","content":"Build a small preload bridge with `createIpcBridge()` or `createAbortableIpcBridge()` so the renderer only sees the operations it is allowed to call."},"408":{"id":"/docs/recipes/electron-pr-review-workbench","page_id":"/docs/recipes/electron-pr-review-workbench","type":"page","content":"Electron PR Review Workbench","breadcrumbs":["Docs","Recipes","Recipes"],"tags":[],"url":"/docs/recipes/electron-pr-review-workbench"},"409":{"id":"/docs/recipes/electron-pr-review-workbench-0","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench","content":"A practical architecture for a GitHub pull-request review desktop app using tuples in the right places and ordinary UI state in the renderer."},"410":{"id":"/docs/recipes/electron-pr-review-workbench-1","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#main-process-contract","content":"Main-process contract"},"411":{"id":"/docs/recipes/electron-pr-review-workbench-2","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#main-process-implementation","content":"Main-process implementation"},"412":{"id":"/docs/recipes/electron-pr-review-workbench-3","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#preload-bridge","content":"Preload bridge"},"413":{"id":"/docs/recipes/electron-pr-review-workbench-4","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#renderer-state","content":"Renderer state"},"414":{"id":"/docs/recipes/electron-pr-review-workbench-5","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#why-this-fits-pr-review-tools-well","content":"Why this fits PR review tools well"},"415":{"id":"/docs/recipes/electron-pr-review-workbench-6","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#good-additions","content":"Good additions"},"416":{"id":"/docs/recipes/electron-pr-review-workbench-7","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#avoid","content":"Avoid"},"417":{"id":"/docs/recipes/electron-pr-review-workbench-8","page_id":"/docs/recipes/electron-pr-review-workbench","type":"heading","tags":[],"url":"/docs/recipes/electron-pr-review-workbench#rule-of-thumb","content":"Rule of thumb"},"418":{"id":"/docs/recipes/electron-pr-review-workbench-9","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench","content":"If you are building a GitHub PR review app in Electron, Yieldless fits best in the main process, preload bridge, and service layer. It is less useful as the shape of your React component state."},"419":{"id":"/docs/recipes/electron-pr-review-workbench-10","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench","content":"That distinction matters:"},"420":{"id":"/docs/recipes/electron-pr-review-workbench-11","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench","content":"Use tuples while you are still doing failure-heavy work: GitHub API calls, local Git reads, diff parsing, cache reads, IPC boundaries."},"421":{"id":"/docs/recipes/electron-pr-review-workbench-12","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench","content":"Once the renderer receives the result, fold it into ordinary screen state and move on."},"422":{"id":"/docs/recipes/electron-pr-review-workbench-13","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#main-process-implementation","content":"The important thing here is not the exact helper list. It is the layering:"},"423":{"id":"/docs/recipes/electron-pr-review-workbench-14","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#main-process-implementation","content":"`yieldless/error` keeps the boundary readable with `ok()` and `err()`."},"424":{"id":"/docs/recipes/electron-pr-review-workbench-15","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#main-process-implementation","content":"`yieldless/all` loads the PR payload in parallel."},"425":{"id":"/docs/recipes/electron-pr-review-workbench-16","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#main-process-implementation","content":"`yieldless/task` gives the whole request one shared cancellation signal."},"426":{"id":"/docs/recipes/electron-pr-review-workbench-17","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#main-process-implementation","content":"`yieldless/node` keeps Git subprocess failures in the same tuple contract."},"427":{"id":"/docs/recipes/electron-pr-review-workbench-18","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#renderer-state","content":"This is the point where Yieldless should usually stop being the dominant shape."},"428":{"id":"/docs/recipes/electron-pr-review-workbench-19","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#renderer-state","content":"That keeps the renderer normal. Components render `idle`, `loading`, `ready`, or `error`. They do not need to carry `[error, value]` through every prop."},"429":{"id":"/docs/recipes/electron-pr-review-workbench-20","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#why-this-fits-pr-review-tools-well","content":"Pull-request work crosses many noisy boundaries: GitHub HTTP, local Git, caches, and Electron IPC."},"430":{"id":"/docs/recipes/electron-pr-review-workbench-21","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#why-this-fits-pr-review-tools-well","content":"Cancellation matters because users jump between PRs quickly and the old load should stop being important."},"431":{"id":"/docs/recipes/electron-pr-review-workbench-22","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#why-this-fits-pr-review-tools-well","content":"The renderer wants stable view state, not a low-level transport shape."},"432":{"id":"/docs/recipes/electron-pr-review-workbench-23","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#good-additions","content":"Deduplicate duplicate PR loads while a user is switching tabs or refreshing panels."},"433":{"id":"/docs/recipes/electron-pr-review-workbench-24","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#good-additions","content":"Use bounded iterable work when processing many files in a diff."},"434":{"id":"/docs/recipes/electron-pr-review-workbench-25","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#avoid","content":"Do not keep tuples as your component model."},"435":{"id":"/docs/recipes/electron-pr-review-workbench-26","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#avoid","content":"Fold the tuple once into `idle`, `loading`, `ready`, and `error` state. UI code should speak in screen states."},"436":{"id":"/docs/recipes/electron-pr-review-workbench-27","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#rule-of-thumb","content":"Use Yieldless in the main process and preload boundary."},"437":{"id":"/docs/recipes/electron-pr-review-workbench-28","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#rule-of-thumb","content":"Convert tuples into domain state at the renderer edge."},"438":{"id":"/docs/recipes/electron-pr-review-workbench-29","page_id":"/docs/recipes/electron-pr-review-workbench","tags":[],"type":"text","url":"/docs/recipes/electron-pr-review-workbench#rule-of-thumb","content":"Do not force tuple results deep into component trees."},"439":{"id":"/docs/recipes/repository-indexer","page_id":"/docs/recipes/repository-indexer","type":"page","content":"Repository Indexer","breadcrumbs":["Docs","Recipes","Recipes"],"tags":[],"url":"/docs/recipes/repository-indexer"},"440":{"id":"/docs/recipes/repository-indexer-0","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"A larger example that combines queues, pub/sub, caching, batching, limits, retries, task groups, and Node subprocesses."},"441":{"id":"/docs/recipes/repository-indexer-1","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#the-indexer","content":"The indexer"},"442":{"id":"/docs/recipes/repository-indexer-2","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#using-it-from-a-route-or-action","content":"Using it from a route or action"},"443":{"id":"/docs/recipes/repository-indexer-3","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"Why this is easier to operate"},"444":{"id":"/docs/recipes/repository-indexer-4","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#smaller-variations","content":"Smaller variations"},"445":{"id":"/docs/recipes/repository-indexer-5","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#process-a-fixed-list-without-a-long-running-queue","content":"Process a fixed list without a long-running queue"},"446":{"id":"/docs/recipes/repository-indexer-6","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#keep-only-the-cache-and-batcher","content":"Keep only the cache and batcher"},"447":{"id":"/docs/recipes/repository-indexer-7","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#add-a-circuit-breaker-to-an-optional-dependency","content":"Add a circuit breaker to an optional dependency"},"448":{"id":"/docs/recipes/repository-indexer-8","page_id":"/docs/recipes/repository-indexer","type":"heading","tags":[],"url":"/docs/recipes/repository-indexer#avoid-hiding-the-pipeline-inside-a-generic-worker-framework","content":"Avoid: hiding the pipeline inside a generic worker framework"},"449":{"id":"/docs/recipes/repository-indexer-9","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"This recipe shows a realistic in-process worker pipeline: a user selects repositories, the app indexes them, progress is streamed to the UI, remote metadata is cached, owner lookups are batched, and local Git subprocesses stay bounded."},"450":{"id":"/docs/recipes/repository-indexer-10","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"The point is not to build a new runtime. The point is to keep the moving parts visible:"},"451":{"id":"/docs/recipes/repository-indexer-11","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/queue` accepts work with backpressure"},"452":{"id":"/docs/recipes/repository-indexer-12","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/pubsub` broadcasts progress"},"453":{"id":"/docs/recipes/repository-indexer-13","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/task` runs workers under one cancellation signal"},"454":{"id":"/docs/recipes/repository-indexer-14","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/limiter` protects API quota and local subprocess capacity"},"455":{"id":"/docs/recipes/repository-indexer-15","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/cache` avoids repeated metadata reads"},"456":{"id":"/docs/recipes/repository-indexer-16","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/batcher` collapses nearby owner lookups"},"457":{"id":"/docs/recipes/repository-indexer-17","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/retry` handles transient remote failures"},"458":{"id":"/docs/recipes/repository-indexer-18","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/fetch` keeps remote calls in tuple form"},"459":{"id":"/docs/recipes/repository-indexer-19","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer","content":"`yieldless/node` wraps local Git commands as tuples"},"460":{"id":"/docs/recipes/repository-indexer-20","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#using-it-from-a-route-or-action","content":"In a real UI, the progress subscription often lives in a websocket, server-sent events stream, or Electron IPC handler. The shape stays the same: subscribe, render events, and abort when the user leaves."},"461":{"id":"/docs/recipes/repository-indexer-21","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"The queue is bounded, so user-selected work cannot grow memory forever."},"462":{"id":"/docs/recipes/repository-indexer-22","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"Worker count is explicit, so local Git subprocesses stay polite."},"463":{"id":"/docs/recipes/repository-indexer-23","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"API quota waits happen before remote calls, not after the upstream complains."},"464":{"id":"/docs/recipes/repository-indexer-24","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"Metadata reads are cached, but failed reads are not stored."},"465":{"id":"/docs/recipes/repository-indexer-25","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"Owner lookups batch together while still returning one result per job."},"466":{"id":"/docs/recipes/repository-indexer-26","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"Retry policy sits around the flaky remote read, not around the whole pipeline."},"467":{"id":"/docs/recipes/repository-indexer-27","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#why-this-is-easier-to-operate","content":"Progress is just an async subscription, so it can feed logs, UI, or tests."},"468":{"id":"/docs/recipes/repository-indexer-28","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#process-a-fixed-list-without-a-long-running-queue","content":"If you already have the whole list and do not need progress fanout, `mapLimit()` is smaller."},"469":{"id":"/docs/recipes/repository-indexer-29","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#keep-only-the-cache-and-batcher","content":"If the pipeline is overkill, keep the read model helpers."},"470":{"id":"/docs/recipes/repository-indexer-30","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#add-a-circuit-breaker-to-an-optional-dependency","content":"If indexing can continue without feature flags or recommendations, wrap that optional remote call with a circuit breaker and use a fallback when it is open."},"471":{"id":"/docs/recipes/repository-indexer-31","page_id":"/docs/recipes/repository-indexer","tags":[],"type":"text","url":"/docs/recipes/repository-indexer#avoid-hiding-the-pipeline-inside-a-generic-worker-framework","content":"That looks shorter, but the operational choices disappear. Yieldless works best when the important limits remain close to the work they protect."},"472":{"id":"/docs/recipes/resilient-service-flow","page_id":"/docs/recipes/resilient-service-flow","type":"page","content":"Resilient Service Flow","breadcrumbs":["Docs","Recipes","Recipes"],"tags":[],"url":"/docs/recipes/resilient-service-flow"},"473":{"id":"/docs/recipes/resilient-service-flow-0","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow","content":"A practical backend flow that combines tuples, retries, validation, routing, and cancellation."},"474":{"id":"/docs/recipes/resilient-service-flow-1","page_id":"/docs/recipes/resilient-service-flow","type":"heading","tags":[],"url":"/docs/recipes/resilient-service-flow#the-moving-parts","content":"The moving parts"},"475":{"id":"/docs/recipes/resilient-service-flow-2","page_id":"/docs/recipes/resilient-service-flow","type":"heading","tags":[],"url":"/docs/recipes/resilient-service-flow#route-handler","content":"Route handler"},"476":{"id":"/docs/recipes/resilient-service-flow-3","page_id":"/docs/recipes/resilient-service-flow","type":"heading","tags":[],"url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"Why this holds up well in production"},"477":{"id":"/docs/recipes/resilient-service-flow-4","page_id":"/docs/recipes/resilient-service-flow","type":"heading","tags":[],"url":"/docs/recipes/resilient-service-flow#good-variation-add-a-remote-dependency","content":"Good variation: add a remote dependency"},"478":{"id":"/docs/recipes/resilient-service-flow-5","page_id":"/docs/recipes/resilient-service-flow","type":"heading","tags":[],"url":"/docs/recipes/resilient-service-flow#avoid-retrying-the-whole-handler","content":"Avoid: retrying the whole handler"},"479":{"id":"/docs/recipes/resilient-service-flow-6","page_id":"/docs/recipes/resilient-service-flow","type":"heading","tags":[],"url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Rules worth keeping"},"480":{"id":"/docs/recipes/resilient-service-flow-7","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow","content":"This recipe shows the shape Yieldless is best at: an HTTP request that validates input, performs a few pieces of I/O, retries the flaky part, and returns a normal JSON response."},"481":{"id":"/docs/recipes/resilient-service-flow-8","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#the-moving-parts","content":"`yieldless/schema` validates input without throwing"},"482":{"id":"/docs/recipes/resilient-service-flow-9","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#the-moving-parts","content":"`yieldless/fetch` keeps HTTP calls in tuple form"},"483":{"id":"/docs/recipes/resilient-service-flow-10","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#the-moving-parts","content":"`yieldless/retry` handles transient I/O noise"},"484":{"id":"/docs/recipes/resilient-service-flow-11","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#the-moving-parts","content":"`yieldless/task` keeps sibling work under one cancellation signal"},"485":{"id":"/docs/recipes/resilient-service-flow-12","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#the-moving-parts","content":"`yieldless/router` turns tuple results into a plain response"},"486":{"id":"/docs/recipes/resilient-service-flow-13","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"Validation failures never take the exception path."},"487":{"id":"/docs/recipes/resilient-service-flow-14","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"If `loadRefs()` fails, `loadStatus()` is aborted immediately."},"488":{"id":"/docs/recipes/resilient-service-flow-15","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"Retry timers are cancellable because they run through `AbortSignal`."},"489":{"id":"/docs/recipes/resilient-service-flow-16","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"The handler body stays linear. There is no framework-specific DSL to learn."},"490":{"id":"/docs/recipes/resilient-service-flow-17","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#good-variation-add-a-remote-dependency","content":"The retry policy is attached to the flaky network call, not to the whole request."},"491":{"id":"/docs/recipes/resilient-service-flow-18","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#avoid-retrying-the-whole-handler","content":"That repeats validation, routing decisions, and any side effects. Retry the noisy boundary instead."},"492":{"id":"/docs/recipes/resilient-service-flow-19","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Validate early and return early."},"493":{"id":"/docs/recipes/resilient-service-flow-20","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Retry only the noisy boundary, not the entire request."},"494":{"id":"/docs/recipes/resilient-service-flow-21","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Spawn sibling work only when both tasks should die together."},"495":{"id":"/docs/recipes/resilient-service-flow-22","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Map domain misses to explicit HTTP errors like `NotFoundError`."},"496":{"id":"/docs/reference/all","page_id":"/docs/reference/all","type":"page","content":"yieldless/all","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/all"},"497":{"id":"/docs/reference/all-0","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all","content":"Tuple-aware parallel combinators that share cancellation."},"498":{"id":"/docs/reference/all-1","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#exports","content":"Exports"},"499":{"id":"/docs/reference/all-2","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#example","content":"Example"},"500":{"id":"/docs/reference/all-3","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#behavior-notes","content":"Behavior notes"},"501":{"id":"/docs/reference/all-4","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#when-to-prefer-runtaskgroup-instead","content":"When to prefer runTaskGroup() instead"},"502":{"id":"/docs/reference/all-5","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#good","content":"Good"},"503":{"id":"/docs/reference/all-6","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#avoid","content":"Avoid"},"504":{"id":"/docs/reference/all-7","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all","content":"`yieldless/all` gives you helpers for tuple-returning parallel work: `all(tasks)` waits for every task or aborts siblings on the first error, `race(tasks)` resolves with the first settled result and aborts the rest, and `mapLimit(items, mapper, options)` processes a collection with bounded concurrency."},"505":{"id":"/docs/reference/all-8","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`type SafeTask<T, E = Error> = (signal: AbortSignal) => PromiseLike<SafeResult<T, E>> | SafeResult<T, E>`"},"506":{"id":"/docs/reference/all-9","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`type MapLimitMapper<Item, Value, E = Error> = (item: Item, index: number, signal: AbortSignal) => PromiseLike<SafeResult<Value, E>> | SafeResult<Value, E>`"},"507":{"id":"/docs/reference/all-10","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`all(tasks, options): Promise<SafeResult<AllValues<Tasks>, ParallelError<Tasks>>>`"},"508":{"id":"/docs/reference/all-11","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`mapLimit(items, mapper, { concurrency, signal }): Promise<SafeResult<Value[], E>>`"},"509":{"id":"/docs/reference/all-12","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`race(tasks, options): Promise<SafeResult<Value, Error>>`"},"510":{"id":"/docs/reference/all-13","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#example","content":"For large batches, use `mapLimit()` to avoid starting every item at once:"},"511":{"id":"/docs/reference/all-14","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`all([])` succeeds with an empty array."},"512":{"id":"/docs/reference/all-15","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit([], mapper, options)` succeeds with an empty array."},"513":{"id":"/docs/reference/all-16","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit()` preserves input order and throws a `RangeError` when `concurrency` is less than `1` or not an integer."},"514":{"id":"/docs/reference/all-17","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race([])` throws a `RangeError`."},"515":{"id":"/docs/reference/all-18","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"If any task or mapped item returns `[error, null]`, siblings are aborted before the final tuple is returned."},"516":{"id":"/docs/reference/all-19","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race()` aborts losing tasks immediately, then waits for them to settle before it returns."},"517":{"id":"/docs/reference/all-20","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"Thrown task and mapper failures are normalized into tuple failures internally."},"518":{"id":"/docs/reference/all-21","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#when-to-prefer-runtaskgroup-instead","content":"Use `all()`, `race()`, and `mapLimit()` when the work is already tuple-native. Use `runTaskGroup()` when you want imperative fan-out and regular promise values."},"519":{"id":"/docs/reference/all-22","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `all()` for a small, fixed set of independent tuple tasks."},"520":{"id":"/docs/reference/all-23","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `mapLimit()` when a list could be large or expensive."},"521":{"id":"/docs/reference/all-24","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `race()` when the first success or first failure should settle the operation."},"522":{"id":"/docs/reference/all-25","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#avoid","content":"Do not pass work that ignores the signal and expect cancellation to be immediate."},"523":{"id":"/docs/reference/all-26","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#avoid","content":"Do not use `all()` for thousands of items. Use `mapLimit()` or `yieldless/iterable` so you can control pressure."},"524":{"id":"/docs/reference/batcher","page_id":"/docs/reference/batcher","type":"page","content":"yieldless/batcher","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/batcher"},"525":{"id":"/docs/reference/batcher-0","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"DataLoader-style keyed batching for tuple-returning async reads."},"526":{"id":"/docs/reference/batcher-1","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#exports","content":"Exports"},"527":{"id":"/docs/reference/batcher-2","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#example","content":"Example"},"528":{"id":"/docs/reference/batcher-3","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#behavior-notes","content":"Behavior notes"},"529":{"id":"/docs/reference/batcher-4","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#good","content":"Good"},"530":{"id":"/docs/reference/batcher-5","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#avoid","content":"Avoid"},"531":{"id":"/docs/reference/batcher-6","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"`yieldless/batcher` coalesces nearby `load(key)` calls into one `loadMany(keys, signal)` call. It is useful when many screens, resolvers, or workflow steps can ask for related data in the same tick."},"532":{"id":"/docs/reference/batcher-7","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"The module stays intentionally boring: it does not cache, it does not add a scheduler, and it does not require a runtime. It batches pending keys, maps results back by index, and returns tuple results to each caller."},"533":{"id":"/docs/reference/batcher-8","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`createBatcher({ loadMany, waitMs, maxBatchSize }): Batcher`"},"534":{"id":"/docs/reference/batcher-9","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`class MissingBatchResultError extends Error`"},"535":{"id":"/docs/reference/batcher-10","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`type Batcher<Key, Value, E> = { load, clear, pending }`"},"536":{"id":"/docs/reference/batcher-11","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`type BatcherLoadOptions = { signal?: AbortSignal }`"},"537":{"id":"/docs/reference/batcher-12","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`waitMs` defaults to `0`, which batches calls queued in the same turn."},"538":{"id":"/docs/reference/batcher-13","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`maxBatchSize` flushes a batch early when enough keys are waiting."},"539":{"id":"/docs/reference/batcher-14","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`loadMany()` must return values in the same order as the input keys."},"540":{"id":"/docs/reference/batcher-15","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"If `loadMany()` returns `[error, null]`, every waiting caller receives that error."},"541":{"id":"/docs/reference/batcher-16","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"If a result is missing for an index, that caller receives `MissingBatchResultError`."},"542":{"id":"/docs/reference/batcher-17","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"A pending `load()` can be aborted before the batch flushes."},"543":{"id":"/docs/reference/batcher-18","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`clear(reason)` resolves all pending loads with the reason."},"544":{"id":"/docs/reference/batcher-19","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#good","content":"Use a batcher where the backend already supports bulk reads."},"545":{"id":"/docs/reference/batcher-20","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#good","content":"Keep caching separate when you need both."},"546":{"id":"/docs/reference/batcher-21","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#avoid","content":"Do not use batching to hide write side effects."},"547":{"id":"/docs/reference/batcher-22","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#avoid","content":"Prefer explicit write orchestration for mutations, and use `yieldless/batcher` for read-like keyed loading."},"548":{"id":"/docs/reference/breaker","page_id":"/docs/reference/breaker","type":"page","content":"yieldless/breaker","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/breaker"},"549":{"id":"/docs/reference/breaker-0","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"Circuit breakers for flaky tuple-returning dependencies."},"550":{"id":"/docs/reference/breaker-1","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#exports","content":"Exports"},"551":{"id":"/docs/reference/breaker-2","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#example","content":"Example"},"552":{"id":"/docs/reference/breaker-3","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#behavior-notes","content":"Behavior notes"},"553":{"id":"/docs/reference/breaker-4","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#good","content":"Good"},"554":{"id":"/docs/reference/breaker-5","page_id":"/docs/reference/breaker","type":"heading","tags":[],"url":"/docs/reference/breaker#avoid","content":"Avoid"},"555":{"id":"/docs/reference/breaker-6","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"`yieldless/breaker` protects a dependency after repeated failures. It tracks a small state machine: `closed`, `open`, and `half-open`. When enough failures trip the breaker, new calls fail fast with `CircuitOpenError` until the cooldown passes."},"556":{"id":"/docs/reference/breaker-7","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker","content":"Use it around external services, subprocess-heavy integrations, or any expensive boundary where repeated failures should stop causing more pressure."},"557":{"id":"/docs/reference/breaker-8","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`createCircuitBreaker(operation, options): CircuitBreaker`"},"558":{"id":"/docs/reference/breaker-9","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`class CircuitOpenError extends Error`"},"559":{"id":"/docs/reference/breaker-10","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreakerState = \"closed\" | \"half-open\" | \"open\"`"},"560":{"id":"/docs/reference/breaker-11","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreakerOptions = { failureThreshold, cooldownMs, successThreshold, shouldTrip, onStateChange }`"},"561":{"id":"/docs/reference/breaker-12","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#exports","content":"`type CircuitBreaker = callable & { state, failureCount, reset }`"},"562":{"id":"/docs/reference/breaker-13","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"The breaker opens after `failureThreshold` tripping failures."},"563":{"id":"/docs/reference/breaker-14","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"While open, calls return `[new CircuitOpenError(), null]`."},"564":{"id":"/docs/reference/breaker-15","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"After `cooldownMs`, the next call moves the breaker to `half-open`."},"565":{"id":"/docs/reference/breaker-16","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"A half-open success closes the breaker once `successThreshold` is reached."},"566":{"id":"/docs/reference/breaker-17","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"A half-open failure opens it again."},"567":{"id":"/docs/reference/breaker-18","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"`shouldTrip(error)` lets you ignore expected failures such as validation errors."},"568":{"id":"/docs/reference/breaker-19","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#behavior-notes","content":"`reset()` closes the breaker and clears counts."},"569":{"id":"/docs/reference/breaker-20","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#good","content":"Trip only on dependency failures, not user input."},"570":{"id":"/docs/reference/breaker-21","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#good","content":"Expose breaker state for diagnostics."},"571":{"id":"/docs/reference/breaker-22","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#avoid","content":"Do not use a circuit breaker for ordinary validation or authorization branches."},"572":{"id":"/docs/reference/breaker-23","page_id":"/docs/reference/breaker","tags":[],"type":"text","url":"/docs/reference/breaker#avoid","content":"Use it for unstable boundaries where failing fast reduces damage."},"573":{"id":"/docs/reference/cache","page_id":"/docs/reference/cache","type":"page","content":"yieldless/cache","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/cache"},"574":{"id":"/docs/reference/cache-0","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache","content":"TTL/LRU tuple caches with in-flight load sharing."},"575":{"id":"/docs/reference/cache-1","page_id":"/docs/reference/cache","type":"heading","tags":[],"url":"/docs/reference/cache#exports","content":"Exports"},"576":{"id":"/docs/reference/cache-2","page_id":"/docs/reference/cache","type":"heading","tags":[],"url":"/docs/reference/cache#example","content":"Example"},"577":{"id":"/docs/reference/cache-3","page_id":"/docs/reference/cache","type":"heading","tags":[],"url":"/docs/reference/cache#behavior-notes","content":"Behavior notes"}
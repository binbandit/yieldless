ple"},"683":{"id":"/docs/reference/cache-3","page_id":"/docs/reference/cache","type":"heading","tags":[],"url":"/docs/reference/cache#behavior-notes","content":"Behavior notes"},"684":{"id":"/docs/reference/cache-4","page_id":"/docs/reference/cache","type":"heading","tags":[],"url":"/docs/reference/cache#good","content":"Good"},"685":{"id":"/docs/reference/cache-5","page_id":"/docs/reference/cache","type":"heading","tags":[],"url":"/docs/reference/cache#avoid","content":"Avoid"},"686":{"id":"/docs/reference/cache-6","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache","content":"`yieldless/cache` stores successful tuple load results and shares in-flight loads for the same key. It is useful for API clients, metadata readers, schema discovery, docs search, and any expensive async read where several callers can ask for the same thing."},"687":{"id":"/docs/reference/cache-7","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache","content":"It is intentionally small: no background worker, no global store, no runtime. The cache loads on demand, expires entries by TTL, evicts least-recently-used entries by size, and keeps errors out of the cache."},"688":{"id":"/docs/reference/cache-8","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`createCache({ load, getKey, maxSize, ttlMs }): Cache`"},"689":{"id":"/docs/reference/cache-9","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`type Cache<Key, Value, E> = { get, refresh, delete, clear, has, stats, size }`"},"690":{"id":"/docs/reference/cache-10","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","content":"`type CacheStats = { hits, misses, inFlight, size }`"},"691":{"id":"/docs/reference/cache-11","page_id":"/docs/reference/cache","tags":[],"type":"text","url":"/docs/reference/cache#exports","conten
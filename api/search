ncy, signal }): Promise<SafeResult<Value[], E>>`"},"183":{"id":"/docs/reference/all-10","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`race(tasks, options): Promise<SafeResult<Value, Error>>`"},"184":{"id":"/docs/reference/all-11","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#example","content":"For large batches, use `mapLimit()` to avoid starting every item at once:"},"185":{"id":"/docs/reference/all-12","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`all([])` succeeds with an empty array."},"186":{"id":"/docs/reference/all-13","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit([], mapper, options)` succeeds with an empty array."},"187":{"id":"/docs/reference/all-14","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit()` preserves input order and throws a `RangeError` when `concurrency` is less than `1` or not an integer."},"188":{"id":"/docs/reference/all-15","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race([])` throws a `RangeError`."},"189":{"id":"/docs/reference/all-16","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"If any task or mapped item returns `[error, null]`, siblings are aborted before the final tuple is returned."},"190":{"id":"/docs/reference/all-17","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race()` aborts losing tasks immediately, then waits for them to settle before it returns."},"191":{"id":"/docs/reference/all-18","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"Thrown task and mapper failures are norm
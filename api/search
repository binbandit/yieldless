s/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"Retry timers are cancellable because they run through `AbortSignal`."},"505":{"id":"/docs/recipes/resilient-service-flow-16","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#why-this-holds-up-well-in-production","content":"The handler body stays linear. There is no framework-specific DSL to learn."},"506":{"id":"/docs/recipes/resilient-service-flow-17","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#good-variation-add-a-remote-dependency","content":"The retry policy is attached to the flaky network call, not to the whole request."},"507":{"id":"/docs/recipes/resilient-service-flow-18","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#avoid-retrying-the-whole-handler","content":"That repeats validation, routing decisions, and any side effects. Retry the noisy boundary instead."},"508":{"id":"/docs/recipes/resilient-service-flow-19","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Validate early and return early."},"509":{"id":"/docs/recipes/resilient-service-flow-20","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Retry only the noisy boundary, not the entire request."},"510":{"id":"/docs/recipes/resilient-service-flow-21","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Spawn sibling work only when both tasks should die together."},"511":{"id":"/docs/recipes/resilient-service-flow-22","page_id":"/docs/recipes/resilient-service-flow","tags":[],"type":"text","url":"/docs/recipes/resilient-service-flow#rules-worth-keeping","content":"Map domain misses to explicit HTTP errors like `NotFoundError`."},"512":{"id":"/docs/reference/all","page_id":"/docs/reference/all","type":"page","content":"yieldless/all","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/all"},"513":{"id":"/docs/reference/all-0","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all","content":"Tuple-aware parallel combinators that share cancellation."},"514":{"id":"/docs/reference/all-1","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#exports","content":"Exports"},"515":{"id":"/docs/reference/all-2","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#example","content":"Example"},"516":{"id":"/docs/reference/all-3","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#behavior-notes","content":"Behavior notes"},"517":{"id":"/docs/reference/all-4","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#when-to-prefer-runtaskgroup-instead","content":"When to prefer runTaskGroup() instead"},"518":{"id":"/docs/reference/all-5","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#good","content":"Good"},"519":{"id":"/docs/reference/all-6","page_id":"/docs/reference/all","type":"heading","tags":[],"url":"/docs/reference/all#avoid","content":"Avoid"},"520":{"id":"/docs/reference/all-7","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all","content":"`yieldless/all` gives you helpers for tuple-returning parallel work: `all(tasks)` waits for every task or aborts siblings on the first error, `race(tasks)` resolves with the first settled result and aborts the rest, and `mapLimit(items, mapper, options)` processes a collection with bounded concurrency."},"521":{"id":"/docs/reference/all-8","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`type SafeTask<T, E = Error> = (signal: AbortSignal) => PromiseLike<SafeResult<T, E>> | SafeResult<T, E>`"},"522":{"id":"/docs/reference/all-9","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`type MapLimitMapper<Item, Value, E = Error> = (item: Item, index: number, signal: AbortSignal) => PromiseLike<SafeResult<Value, E>> | SafeResult<Value, E>`"},"523":{"id":"/docs/reference/all-10","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`all(tasks, options): Promise<SafeResult<AllValues<Tasks>, ParallelError<Tasks>>>`"},"524":{"id":"/docs/reference/all-11","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`mapLimit(items, mapper, { concurrency, signal }): Promise<SafeResult<Value[], E>>`"},"525":{"id":"/docs/reference/all-12","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#exports","content":"`race(tasks, options): Promise<SafeResult<Value, Error>>`"},"526":{"id":"/docs/reference/all-13","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#example","content":"For large batches, use `mapLimit()` to avoid starting every item at once:"},"527":{"id":"/docs/reference/all-14","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`all([])` succeeds with an empty array."},"528":{"id":"/docs/reference/all-15","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit([], mapper, options)` succeeds with an empty array."},"529":{"id":"/docs/reference/all-16","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`mapLimit()` preserves input order and throws a `RangeError` when `concurrency` is less than `1` or not an integer."},"530":{"id":"/docs/reference/all-17","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race([])` throws a `RangeError`."},"531":{"id":"/docs/reference/all-18","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"If any task or mapped item returns `[error, null]`, siblings are aborted before the final tuple is returned."},"532":{"id":"/docs/reference/all-19","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"`race()` aborts losing tasks immediately, then waits for them to settle before it returns."},"533":{"id":"/docs/reference/all-20","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#behavior-notes","content":"Thrown task and mapper failures are normalized into tuple failures internally."},"534":{"id":"/docs/reference/all-21","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#when-to-prefer-runtaskgroup-instead","content":"Use `all()`, `race()`, and `mapLimit()` when the work is already tuple-native. Use `runTaskGroup()` when you want imperative fan-out and regular promise values."},"535":{"id":"/docs/reference/all-22","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `all()` for a small, fixed set of independent tuple tasks."},"536":{"id":"/docs/reference/all-23","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `mapLimit()` when a list could be large or expensive."},"537":{"id":"/docs/reference/all-24","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#good","content":"Use `race()` when the first success or first failure should settle the operation."},"538":{"id":"/docs/reference/all-25","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#avoid","content":"Do not pass work that ignores the signal and expect cancellation to be immediate."},"539":{"id":"/docs/reference/all-26","page_id":"/docs/reference/all","tags":[],"type":"text","url":"/docs/reference/all#avoid","content":"Do not use `all()` for thousands of items. Use `mapLimit()` or `yieldless/iterable` so you can control pressure."},"540":{"id":"/docs/reference/batcher","page_id":"/docs/reference/batcher","type":"page","content":"yieldless/batcher","breadcrumbs":["Docs","Reference","Reference"],"tags":[],"url":"/docs/reference/batcher"},"541":{"id":"/docs/reference/batcher-0","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"DataLoader-style keyed batching for tuple-returning async reads."},"542":{"id":"/docs/reference/batcher-1","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#exports","content":"Exports"},"543":{"id":"/docs/reference/batcher-2","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#example","content":"Example"},"544":{"id":"/docs/reference/batcher-3","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#behavior-notes","content":"Behavior notes"},"545":{"id":"/docs/reference/batcher-4","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#good","content":"Good"},"546":{"id":"/docs/reference/batcher-5","page_id":"/docs/reference/batcher","type":"heading","tags":[],"url":"/docs/reference/batcher#avoid","content":"Avoid"},"547":{"id":"/docs/reference/batcher-6","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"`yieldless/batcher` coalesces nearby `load(key)` calls into one `loadMany(keys, signal)` call. It is useful when many screens, resolvers, or workflow steps can ask for related data in the same tick."},"548":{"id":"/docs/reference/batcher-7","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher","content":"The module stays intentionally boring: it does not cache, it does not add a scheduler, and it does not require a runtime. It batches pending keys, maps results back by index, and returns tuple results to each caller."},"549":{"id":"/docs/reference/batcher-8","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`createBatcher({ loadMany, waitMs, maxBatchSize }): Batcher`"},"550":{"id":"/docs/reference/batcher-9","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`class MissingBatchResultError extends Error`"},"551":{"id":"/docs/reference/batcher-10","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`type Batcher<Key, Value, E> = { load, clear, pending }`"},"552":{"id":"/docs/reference/batcher-11","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#exports","content":"`type BatcherLoadOptions = { signal?: AbortSignal }`"},"553":{"id":"/docs/reference/batcher-12","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`waitMs` defaults to `0`, which batches calls queued in the same turn."},"554":{"id":"/docs/reference/batcher-13","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`maxBatchSize` flushes a batch early when enough keys are waiting."},"555":{"id":"/docs/reference/batcher-14","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes","content":"`loadMany()` must return values in the same order as the input keys."},"556":{"id":"/docs/reference/batcher-15","page_id":"/docs/reference/batcher","tags":[],"type":"text","url":"/docs/reference/batcher#behavior-notes",